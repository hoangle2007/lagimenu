# PostgreSQL (cài trực tiếp trên máy; quản lý qua psql hoặc pgAdmin 4).
# ECONNREFUSED = chưa có Postgres lắng nghe trên host:port.
# DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/DBNAME
# Nếu thấy 'role "kivomenu" does not exist' -> tạo role + DB:
#   psql -h 127.0.0.1 -p 5432 -U postgres -f src/db/scripts/create-kivomenu-role.sql
# Hoặc paste nội dung file SQL đó vào pgAdmin 4 -> Query Tool (kết nối bằng user superuser 'postgres').
# (sửa YOUR_PASSWORD trong file SQL trước khi chạy; lệnh psql chạy từ thư mục packages/backend)
DATABASE_URL=
PORT=3001
NODE_ENV=development
JWT_SECRET=your-secret-key-min-32-chars-here-change-in-prod
FRONTEND_URL=http://localhost:3000

# ─── Firebase Cloud Messaging (Push Notifications) ────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Client secret: GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Client ID: xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ─── Web Push (VAPID) ───────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional contact for push subscription (mailto: or https:)
VAPID_SUBJECT=mailto:support@example.com

# ─── SMTP (optional — merchant approval emails, invites) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Rate limiting ───────────────────────────────────────────────────────────────
THROTTLE_LIMIT=60

# ─── Upload (ảnh món / logo) ─────────────────────────────────────────────────────
# Cách 1 — Cloudflare R2 (public, production): bật Public access trên bucket + Custom Domain hoặc r2.dev
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public URL không có / cuối (vd https://pub-xxxxx.r2.dev hoặc https://cdn.example.com)
R2_PUBLIC_URL=

# Cách 2 — Dev cục bộ (chỉ bật khi KHÔNG dùng R2; nếu set UPLOAD_LOCAL_DIR thì ưu tiên lưu local)
# UPLOAD_LOCAL_DIR=./uploads-local
# PUBLIC_WEB_ORIGIN=http://localhost:3000