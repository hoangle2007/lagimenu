{
  "name": "kivo-menu-monolist",
  "version": "1.0.0",
  "description": "Kivo Menu - QR Ordering System",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "dev:mobile": "cd packages/mobile && flutter run -d web-server --web-port 5002 --web-hostname 0.0.0.0",
    "dev": "npm run dev:backend & npm run dev:frontend",
    "build": "npm run build -w packages/backend && npm run build -w packages/frontend"
  },
  "devDependencies": {
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "socket.io-client": "4.8.3"
  }
}